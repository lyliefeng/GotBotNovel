{
  "name": "gotbotnovel-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "GotBotNovel cross-platform desktop application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg --arm64",
    "dist:win": "electron-builder --win dir --x64",
    "dist:win:installer": "electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.lyliefeng.gotbotnovel",
    "productName": "GotBotNovel",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/backend_bin",
        "to": "backend_bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/embedding_model",
        "to": "embedding_model",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/static",
        "to": "static",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "GotBotNovel"
    }
  }
}
