{
  "name": "gotbotnovel-desktop",
  "version": "1.0.2",
  "private": true,
  "description": "GotBotNovel cross-platform desktop application",
  "main": "main.js",
  "gotbotUpdate": {
    "giteeApiBase": "https://gitee.com/api/v5",
    "giteeOwner": "lyliefeng",
    "giteeRepo": "GotBotNovel"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg zip --arm64",
    "dist:win": "electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.lyliefeng.gotbotnovel",
    "productName": "GotBotNovel",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "updater.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/backend_bin",
        "to": "backend_bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/embedding_model",
        "to": "embedding_model",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/static",
        "to": "static",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSLocalNetworkUsageDescription": "GotBotNovel 需要访问本机网络，以连接随应用启动的本地服务。",
        "NSDocumentsFolderUsageDescription": "GotBotNovel 需要在您选择时从“文稿”文件夹导入或导出内容。",
        "NSDownloadsFolderUsageDescription": "GotBotNovel 需要在您选择时从“下载”文件夹导入或导出内容。",
        "NSDesktopFolderUsageDescription": "GotBotNovel 需要在您选择时从“桌面”文件夹导入或导出内容。"
      }
    },
    "dmg": {
      "title": "GotBotNovel ${version}",
      "contents": [
        {
          "x": 140,
          "y": 220,
          "type": "file"
        },
        {
          "x": 500,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 320,
          "y": 400,
          "type": "file",
          "path": "resources/macos/macOS-首次运行与权限说明.html"
        }
      ],
      "window": {
        "width": 640,
        "height": 520
      }
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://127.0.0.1:8000/api/desktop-updates"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
